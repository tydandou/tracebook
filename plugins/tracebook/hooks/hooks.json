{
  "description": "Remind Codex to load Tracebook context and evaluate its durable write gate for repository work.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$PLUGIN_ROOT/hooks/tracebook_hook.py\"",
            "commandWindows": "python \"%PLUGIN_ROOT%\\hooks\\tracebook_hook.py\"",
            "timeout": 5,
            "statusMessage": "Applying Tracebook workflow"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$PLUGIN_ROOT/hooks/tracebook_hook.py\"",
            "commandWindows": "python \"%PLUGIN_ROOT%\\hooks\\tracebook_hook.py\"",
            "timeout": 5,
            "statusMessage": "Checking Tracebook write gate"
          }
        ]
      }
    ]
  }
}
